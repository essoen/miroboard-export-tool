{
  "name": "miro-migrator",
  "version": "0.1.0",
  "description": "Migrate Miro boards to Obsidian Canvas and Markdown",
  "type": "module",
  "bin": {
    "miro-migrate": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@mirohq/miro-api": "^2.2.4",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  }
}
